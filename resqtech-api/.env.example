# ── Mode ──────────────────────────────────────────────────────────────────────
# Set to "true" to run entirely on in-memory mock data (no cloud credentials needed)
DEMO_MODE=true

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Supabase (required when DEMO_MODE=false) ──────────────────────────────────
# Get from: supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── Anthropic Claude (optional — falls back to mock triage if not set) ────────
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Twilio SMS (optional — logs to console if not set) ────────────────────────
# Get from: twilio.com → Console
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token_here
TWILIO_PHONE=+1234567890

# ── Google Maps (optional — for future routing features) ──────────────────────
# Get from: console.cloud.google.com → APIs & Services
GOOGLE_MAPS_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
